---
import { Menu, X, ChevronDown } from 'lucide-astro';
import logo1 from '../assets/logo1.png';

const navItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Servicios', href: '/#servicios' },
  { 
    name: 'Productos', 
    href: '/#productos',
    submenu: [
      { name: 'Efficient', href: '/efficient' },
      { name: 'Efficient Plus', href: '/efficient-plus' },
      { name: 'POS Dynamic', href: '/pos-dynamic' },
      { name: 'Nomina+', href: '/nomina' },
      { name: 'LABITPLUS', href: '/labit-plus' },
      { name: 'SICAD', href: '/sicad' },
      { name: 'Barber\'s', href: '/barbers' },
      { name: 'Carwash PRO', href: '/carwashpro' },
    ]
  },
  { name: 'Sobre Nosotros', href: '/#acerca' },
  { name: 'Vacantes', href: '/vacantes' },
];
---

<nav class="navbar">
  <div class="container nav-content">
    <a href="/" class="logo">
      <img src={logo1.src} alt="SAPINF Logo" class="nav-logo" />
    </a>
    
    <!-- Desktop Links -->
    <ul class="nav-links">
      {navItems.map(item => (
        <li class={item.submenu ? 'nav-item has-submenu' : 'nav-item'}>
          <a href={item.submenu ? '#' : item.href} class={item.submenu ? 'desktop-submenu-toggle' : ''}>
            {item.name}
            {item.submenu && <ChevronDown size={16} class="chevron" />}
          </a>
          {item.submenu && (
            <ul class="submenu shadow-premium">
              {item.submenu.map(subItem => (
                <li><a href={subItem.href}>{subItem.name}</a></li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>

    <div class="nav-actions">
      <a href="https://wa.me/50494583355" class="btn btn-primary hide-mobile">Contáctanos</a>
      
      <button id="menu-trigger" class="mobile-menu-btn" aria-label="Abrir menú">
        <Menu size={32} />
      </button>
    </div>
  </div>

  <!-- Mobile Overlay Menu -->
  <div id="mobile-overlay" class="mobile-overlay">
    <div class="overlay-content">
      <div class="overlay-header">
        <img src={logo1.src} alt="SAPINF Logo" class="nav-logo" />
        <button id="menu-close" class="mobile-menu-btn" aria-label="Cerrar menú">
          <X size={32} />
        </button>
      </div>
      
      <ul class="mobile-nav-list">
        {navItems.map(item => (
          <li class={item.submenu ? 'mobile-has-submenu' : ''}>
            <a href={item.submenu ? '#' : item.href} class={item.submenu ? 'mobile-nav-link mobile-submenu-toggle' : 'mobile-nav-link'}>
              {item.name}
              {item.submenu && <ChevronDown size={20} class="mobile-chevron" />}
            </a>
            {item.submenu && (
              <ul class="mobile-submenu hidden-submenu">
                {item.submenu.map(subItem => (
                  <li><a href={subItem.href} class="mobile-submenu-link">{subItem.name}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
        <li class="mt-4">
          <a href="https://wa.me/50494583355" class="btn btn-primary w-full justify-center">Contáctanos</a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  const trigger = document.getElementById('menu-trigger');
  const close = document.getElementById('menu-close');
  const overlay = document.getElementById('mobile-overlay');

  if (trigger && close && overlay) {
    trigger.addEventListener('click', () => {
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden'; // Evitar scroll al estar abierto
    });

    close.addEventListener('click', () => {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    });

    // Cerrar al clickear un link que NO sea toggle
    const links = document.querySelectorAll('.mobile-nav-link:not(.mobile-submenu-toggle), .mobile-submenu-link');
    links.forEach(link => {
      link.addEventListener('click', () => {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      });
    });

    // Toggle de Submenú en Desktop
    const desktopToggles = document.querySelectorAll('.desktop-submenu-toggle');
    desktopToggles.forEach(toggle => {
      toggle.addEventListener('click', (e) => {
        e.preventDefault();
        const parentLi = toggle.closest('.has-submenu');
        // Cerrar otros
        document.querySelectorAll('.has-submenu.active-dropdown').forEach(item => {
          if (item !== parentLi) item.classList.remove('active-dropdown');
        });
        parentLi.classList.toggle('active-dropdown');
      });
    });

    // Cerrar submenu desktop si se hace click fuera
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.has-submenu')) {
        document.querySelectorAll('.has-submenu.active-dropdown').forEach(item => {
          item.classList.remove('active-dropdown');
        });
      }
    });

    // Toggle de Submenú en Móvil
    const mobileToggles = document.querySelectorAll('.mobile-submenu-toggle');
    mobileToggles.forEach(toggle => {
      toggle.addEventListener('click', (e) => {
        e.preventDefault();
        const parentLi = toggle.closest('.mobile-has-submenu');
        parentLi.classList.toggle('active-mobile-dropdown');
      });
    });
  }
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 0.75rem 0;
    margin: 0; /* Removed 1rem margin */
    border-radius: 0; /* Removed 1rem border-radius to be flush */
    background: #011748;
    box-shadow: none;
    border: none;
  }

  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo {
    height: 40px;
    width: auto;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-item {
    position: relative;
    padding: 0.5rem 0;
  }

  .nav-links a {
    font-weight: 600;
    color: #f8fafc;
    transition: color 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .nav-links a:hover {
    color: var(--primary-light);
  }

  .chevron {
    transition: transform 0.3s ease;
  }

  .nav-item:hover .chevron,
  .nav-item.active-dropdown .chevron {
    transform: rotate(180deg);
  }

  /* Submenu Desktop */
  .submenu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: #011748;
    min-width: 220px;
    padding: 1rem 0;
    border-radius: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    list-style: none;
    display: none;
    z-index: 100;
  }

  .nav-item:hover .submenu,
  .nav-item.active-dropdown .submenu {
    display: block;
    animation: fadeInSlide 0.3s ease forwards;
  }

  @keyframes fadeInSlide {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(5px);
    }
  }

  .submenu li a {
    display: block;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.8);
    transition: all 0.2s ease;
    justify-content: flex-start;
  }

  .submenu li a:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--primary-light);
    padding-left: 1.75rem;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 0.5rem;
  }

  /* Mobile Overlay */
  .mobile-overlay {
    position: fixed;
    top: 0;
    right: -100%;
    width: 100%;
    height: 100vh;
    background: #011748;
    z-index: 2000;
    transition: right 0.4s cubic-bezier(0.77, 0, 0.175, 1);
    padding: 2rem;
  }

  .mobile-overlay.active {
    right: 0;
  }

  .overlay-content {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .overlay-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3rem;
  }

  .mobile-nav-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .mobile-nav-link {
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0;
  }

  .mobile-chevron {
    transition: transform 0.3s ease;
  }

  .mobile-has-submenu.active-mobile-dropdown .mobile-chevron {
    transform: rotate(180deg);
  }

  .mobile-submenu {
    list-style: none;
    padding-left: 1.5rem;
    margin-top: 0.5rem;
    display: none;
    flex-direction: column;
    gap: 1rem;
    border-left: 2px solid rgba(255,255,255,0.1);
  }

  .mobile-has-submenu.active-mobile-dropdown .mobile-submenu {
    display: flex;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .mobile-submenu-link {
    font-size: 1.1rem;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    transition: color 0.2s ease;
  }

  .mobile-submenu-link:hover {
    color: var(--primary-light);
  }

  .mt-4 {
    margin-top: 1rem;
  }

  .w-full {
    width: 100%;
  }

  .justify-center {
    justify-content: center;
  }

  @media (max-width: 991px) {
    .nav-links, .hide-mobile {
      display: none;
    }
    
    .mobile-menu-btn {
      display: block;
    }
    
    .navbar {
      margin: 0;
      border-radius: 0;
    }
  }
</style>
