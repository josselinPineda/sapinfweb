---
import { Search, Code2, Globe, GraduationCap, ArrowRight, Cpu } from 'lucide-astro';

const whatsappBase = "https://wa.me/50494583355?text=";

const services = [
  {
    title: 'Auditoría de Sistemas',
    description: 'Evaluamos la integridad y eficiencia de tus sistemas actuales para garantizar seguridad y rendimiento óptimo.',
    icon: Search,
    href: `${whatsappBase}Hola,%20me%20interesa%20el%20servicio%20de%20Auditoría%20de%20Sistemas`,
  },
  {
    title: 'Consultoría Informática',
    description: 'Asesoramiento experto para la toma de decisiones tecnológicas estratégicas que impulsen tu crecimiento.',
    icon: Code2,
    href: `${whatsappBase}Hola,%20me%20interesa%20el%20servicio%20de%20Consultoría%20Informática`,
  },
  {
    title: 'Desarrollo a Medida',
    description: 'Programamos lo que tu negocio o proyecto personal necesite. Transformamos tus ideas en aplicaciones de software potentes y funcionales.',
    icon: Cpu,
    href: `${whatsappBase}Hola,%20me%20interesa%20el%20servicio%20de%20Desarrollo%20a%20Medida`,
  },
  {
    title: 'Diseño WEB',
    description: 'Creamos experiencias digitales modernas, rápidas y adaptadas a cualquier dispositivo para tu marca.',
    icon: Globe,
    href: `${whatsappBase}Hola,%20me%20interesa%20el%20servicio%20de%20Diseño%20WEB`,
  },
  {
    title: 'Capacitaciones',
    description: 'Formamos a tu equipo en las últimas herramientas y mejores prácticas del sector tecnológico.',
    icon: GraduationCap,
    href: `${whatsappBase}Hola,%20me%20interesa%20el%20servicio%20de%20Capacitaciones`,
  },
];
---

<section id="servicios" class="services">
  <div class="container">
    <div class="section-header">
      <div class="badge">
        <span class="subtitle">Nuestras Soluciones</span>
      </div>
      <h2>Servicios de <span class="highlight">Excelencia</span></h2>
      <p class="section-desc">Ofrecemos un abanico completo de servicios informáticos diseñados para cubrir cada necesidad técnica de tu empresa.</p>
    </div>

    <div class="services-grid">
      {services.map(service => (
        <div class="service-card">
          <div class="icon-wrapper">
             <service.icon size={32} />
          </div>
          <h3>{service.title}</h3>
          <p>{service.description}</p>
          <a href={service.href} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm mt-4 inline-flex items-center gap-2">
            Más Información <ArrowRight size={16} />
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 6rem 0;
    background: var(--bg-soft);
  }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .badge {
    background: #e1effe;
    padding: 0.6rem 2.5rem;
    border-radius: 9999px;
    margin-bottom: 2rem;
    display: inline-block;
    border: 1px solid #bfdbfe;
  }

  .subtitle {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 800;
    color: var(--primary);
    font-size: 0.9rem;
  }

  h2 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    color: #111827;
    line-height: 1.1;
    margin-bottom: 2rem;
  }

  .highlight {
    color: var(--primary);
    position: relative;
    display: inline-block;
  }

  .section-desc {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  /* Responsividad para móviles y tablets */
  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services {
      padding: 4rem 0;
    }
    .section-header {
      margin-bottom: 3rem;
    }
    .services-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .service-card {
      padding: 1.5rem;
    }
  }

  .service-card {
    background: var(--bg);
    border: 1px solid rgba(0, 102, 204, 0.1);
    box-shadow: 0 10px 30px rgba(0, 102, 204, 0.05);
    padding: 2.5rem;
    border-radius: 1.5rem;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .service-card:hover {
    transform: translateY(-10px);
    border-color: var(--primary-light);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }

  .icon-wrapper {
    width: 64px;
    height: 64px;
    background: var(--primary);
    color: white;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: var(--transition);
  }

  .service-card:hover .icon-wrapper {
    background: var(--accent);
    color: var(--primary-dark);
    transform: rotate(10deg);
  }

  h3 {
    margin-bottom: 1rem;
    color: var(--text);
  }

  .service-card p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }
</style>
