---
import acercadenosotros from '../assets/acercadenosotros.jpg';

const placeholderImage = acercadenosotros.src;
---

<section id="acerca" class="about-section">
  <div class="container relative">
    <div class="about-grid">
      <div class="about-text">
        <div class="badge">
          <span class="subtitle">Conócenos</span>
        </div>
        <h2>Acerca de <span class="highlight">nosotros</span></h2>
        <p class="section-desc">Contamos con un equipo de profesionales en donde se mezcla la experiencia con la innovación, ideas frescas, ingenieros capaces de pensar y desarrollar enfoques innovadores a problemas complejos.</p>
      </div>
      
      <div class="about-media">
        <div class="glow-blob"></div>
        <img src={placeholderImage} alt="Equipo SAPINF" class="hero-img" />
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 8rem 0;
    background: var(--bg-soft);
    overflow: hidden; 
  }

  .about-grid {
    display: grid;
    grid-template-columns: 45% 55%;
    align-items: center;
    gap: 4rem;
  }

  .about-text {
    padding-right: 2rem;
  }

  .badge {
    background: rgba(0, 102, 204, 0.15); 
    padding: 0.5rem 1.5rem;
    border-radius: 2rem;
    margin-bottom: 1.5rem;
    display: inline-block;
    border: 1px solid rgba(0, 102, 204, 0.3);
  }

  .subtitle {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 800;
    color: var(--primary);
    font-size: 0.85rem;
  }

  .about-text h2 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    margin: 0 0 1.5rem 0;
    color: var(--text);
    line-height: 1.1;
  }

  .highlight {
    color: var(--primary);
    position: relative;
    display: inline-block;
  }

  .highlight::after {
    content: '';
    position: absolute;
    bottom: 5px;
    left: 0;
    width: 100%;
    height: 30%;
    background: var(--accent);
    opacity: 0.8;
    z-index: -1;
    border-radius: 4px;
    transform: skewX(-15deg);
  }

  .section-desc {
    color: var(--text-muted);
    font-size: 1.15rem;
    line-height: 1.8;
  }

  .about-media {
    position: relative;
    display: flex;
    justify-content: center; 
    align-items: center;
  }


  .hero-img {
    position: relative;
 
    z-index: 1;
    width: 100%;
    max-width: 600px;
    height: auto;
    object-fit: contain;
    border-radius: 2rem;
    box-shadow: 0 25px 50px rgba(0, 102, 204, 0.15); /* Sombra tintada en azul */
    border: 4px solid white; /* Borde estilo retrato moderno */
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .hero-img:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 35px 60px rgba(0, 102, 204, 0.2);
  }

  @keyframes float {
    0% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -45%) scale(1.05); }
    100% { transform: translate(-50%, -50%) scale(1); }
  }

  @media (max-width: 992px) {
    .about-section {
      padding: 4rem 0;
    }
    .about-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .about-text {
      padding-right: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .about-media {
      justify-content: center;
    }

    .hero-img {
      width: 100%;
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>