---
import { Lightbulb, ShieldCheck, ListOrdered, Handshake, Users, Heart, Scale } from 'lucide-astro';

const valores = [
  { title: "Creatividad", icon: Lightbulb },
  { title: "Responsabilidad", icon: ShieldCheck },
  { title: "Orden", icon: ListOrdered },
  { title: "Honestidad", icon: Handshake },
  { title: "Espíritu de equipo", icon: Users },
  { title: "Respeto", icon: Heart },
  { title: "Integridad", icon: Scale }
];
---

<section id="valores" class="values-section">
  <div class="container">
    <div class="section-header">
      <div class="badge">
        <span class="subtitle">Nuestros Principios</span>
      </div>
      <h2>Nuestros <span class="highlight">valores</span></h2>
      <p class="section-desc">Poniendo en práctica los pilares fundamentales que guían nuestro trabajo día a día.</p>
    </div>
    
    <div class="values-container">
      <div class="values-row">
        {valores.slice(0, 4).map(valor => (
          <div class="value-card">
            <div class="icon-wrapper">
               <valor.icon size={36} strokeWidth={1.5} />
            </div>
            <h3>{valor.title}</h3>
            <div class="card-line"></div>
          </div>
        ))}
      </div>
      <div class="values-row centered-row">
        {valores.slice(4).map(valor => (
          <div class="value-card">
            <div class="icon-wrapper">
               <valor.icon size={36} strokeWidth={1.5} />
            </div>
            <h3>{valor.title}</h3>
            <div class="card-line"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .values-section {
    padding: 8rem 0;
    background: var(--bg-soft);
  }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .badge {
    background: rgba(0, 102, 204, 0.15); 
    padding: 0.5rem 1.5rem;
    border-radius: 2rem;
    margin-bottom: 1.5rem;
    display: inline-block;
    border: 1px solid rgba(0, 102, 204, 0.3);
  }

  .subtitle {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 800;
    color: var(--primary);
    font-size: 0.85rem;
  }

  h2 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    margin: 0 0 1.5rem 0;
    color: var(--text);
    line-height: 1.1;
  }

  .highlight {
    color: var(--primary);
    position: relative;
    display: inline-block;
  }

  .highlight::after {
    content: '';
    position: absolute;
    bottom: 5px;
    left: 0;
    width: 100%;
    height: 30%;
    background: var(--accent); /* Celeste muy suavecito de la paleta */
    opacity: 0.6; 
    z-index: -1;
    border-radius: 4px;
    transform: skewX(-15deg);
  }

  .section-desc {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .values-container {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .values-row {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
    justify-content: center;
  }

  .value-card {
    flex: 0 1 250px;
    background: var(--bg);
    border: 1px solid rgba(0, 0, 0, 0.05); /* Borde apenas visible grisaceo */
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03); /* Sombra gris neutral, sin tinte azul */
    padding: 2.5rem 1.5rem;
    border-radius: 1rem;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .value-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.1);
  }

  /* Íconos con color azul estético y hermoso */
  .icon-wrapper {
    width: 70px;
    height: 70px;
    background: rgba(0, 102, 204, 0.08); /* Fondo sutil celeste que los enmarca */
    color: var(--primary); /* El color azul brillante e institucional */
    border-radius: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .value-card:hover .icon-wrapper {
    transform: scale(1.15) translateY(-5px);
    background: var(--primary); /* Se pinta de azul al pasar el ratón */
    color: white; 
    box-shadow: 0 10px 25px rgba(0, 102, 204, 0.3);
  }

  h3 {
    margin: 0 0 1rem 0;
    color: var(--text);
    font-size: 1.15rem;
    font-weight: 700;
  }

  /* Una línea inferior puramente decorativa neutra */
  .card-line {
    width: 30px;
    height: 3px;
    background: rgba(0,0,0,0.1);
    border-radius: 2px;
    transition: width 0.3s ease, background 0.3s ease;
  }

  .value-card:hover .card-line {
    width: 50px;
    background: var(--primary-light); /* Reflejo sutil azul al interactuar */
  }
</style>
