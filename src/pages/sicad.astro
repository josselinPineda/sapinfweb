---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { 
  CheckCircle2, 
  MessageCircle,
  Layers,
  ShieldCheck,
  Globe,
  TrendingUp,
  Users,
  Settings,
  ShoppingBag,
  Package,
  CreditCard,
  Calculator,
  Receipt,
  Wallet,
  Monitor,
  Landmark,
  ClipboardList,
  Shield
} from 'lucide-astro';
import sicadFondo from '../assets/sicad-fondo.jpg';
import sicadLogo from '../assets/SICAD.png';

const pageTitle = "SICAD - Sistema de Control Administrativo";
---

<Layout title={pageTitle}>
  <Navbar />
  
  <main class="sicad-page">
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container hero-grid">
        <div class="hero-content">
          <div class="badge">
            <span class="subtitle">ERP Empresarial</span>
          </div>
          <div class="product-logo-container">
            <img src={sicadLogo.src} alt="SICAD ERP Logo" class="product-logo" />
          </div>
          <h1>¡El ERP ideal para <span class="highlight">tu empresa</span>!</h1>
          <p class="hero-desc">Lleva tu empresa a otro nivel con nuestro sistema de control administrativo.</p>
          <div class="hero-actions">
            <a href="https://wa.me/50494583355?text=Hola,%20me%20gustaría%20mucha%20más%20información%20sobre%20el%20ERP%20SICAD" target="_blank" rel="noopener noreferrer" class="btn-primary-large">
              <MessageCircle size={24} />
              Solicitar Demostración
            </a>
          </div>
        </div>
        
        <div class="hero-visual">
          <div class="image-wrapper">
             <img src={sicadFondo.src} alt="Interfaz del sistema SICAD" class="main-hero-image" />
          </div>
        </div>
      </div>
    </section>

    <!-- Core Benefits Section -->
    <section class="benefits-section">
      <div class="container">
        <div class="section-header">
           <div class="badge">
             <span class="subtitle">Beneficios Principales</span>
           </div>
           <h2>Diseñado para el <span class="highlight">Éxito</span></h2>
        </div>
        
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="icon-box"><Layers size={28} /></div>
            <h3>100% Integrado</h3>
            <p>Trabaja con todos los módulos de forma sincronizada y fluida.</p>
          </div>
          <div class="benefit-card">
            <div class="icon-box"><ShieldCheck size={28} /></div>
            <h3>Datos Únicos</h3>
            <p>Evita la duplicidad de datos en tu organización.</p>
          </div>
          <div class="benefit-card">
            <div class="icon-box"><Globe size={28} /></div>
            <h3>Global</h3>
            <p>Soporte completo Multimoneda y Multiempresa.</p>
          </div>
          <div class="benefit-card">
            <div class="icon-box"><TrendingUp size={28} /></div>
            <h3>Escalable</h3>
            <p>Crece junto a tu empresa adaptándose a nuevas demandas.</p>
          </div>
          <div class="benefit-card">
            <div class="icon-box"><Users size={28} /></div>
            <h3>Multiusuario</h3>
            <p>Trabajadores y equipos colaborando sin límites de conexión.</p>
          </div>
          <div class="benefit-card">
            <div class="icon-box"><Settings size={28} /></div>
            <h3>Personalizado</h3>
            <p>Diseñado para operar eficientemente en distintas industrias.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Description Block -->
    <section class="desc-block-section">
       <div class="container text-center max-w-4xl mx-auto">
          <div class="glass-desc-card">
             <h3 class="desc-title">Mejora la <span class="highlight">eficiencia, productividad y rentabilidad</span> de tu empresa.</h3>
             <div class="desc-content">
                <p>Automatiza procesos empresariales claves y obtén una visión integrada de la información de tu empresa. Mejora la toma de decisiones al proporcionar información en tiempo real y análisis de datos. Reduce costos al optimizar los procesos y mejorar la gestión de inventarios.</p>
             </div>
          </div>
       </div>
    </section>

    <!-- Modules Grid -->
    <section class="features-section">
      <div class="container">
        <div class="section-header">
           <div class="badge">
             <span class="subtitle">Ecosistema SICAD</span>
           </div>
           <h2>Conoce más acerca de nuestros <span class="highlight">Módulos</span></h2>
        </div>
        
        <div class="features-grid">
          <div class="modern-card">
            <div class="feature-icon"><ShoppingBag size={32} /></div>
            <h3>Compras</h3>
          </div>
          <div class="modern-card">
            <div class="feature-icon"><Package size={32} /></div>
            <h3>Inventarios</h3>
          </div>
          <div class="modern-card">
            <div class="feature-icon"><CreditCard size={32} /></div>
            <h3>Cuentas por pagar</h3>
          </div>
          <div class="modern-card">
            <div class="feature-icon"><Calculator size={32} /></div>
            <h3>Contabilidad</h3>
          </div>
          <div class="modern-card">
            <div class="feature-icon"><Receipt size={32} /></div>
            <h3>Facturación</h3>
          </div>
          <div class="modern-card">
            <div class="feature-icon"><Wallet size={32} /></div>
            <h3>Cuentas por cobrar</h3>
          </div>
          <div class="modern-card">
            <div class="feature-icon"><Monitor size={32} /></div>
            <h3>Activos fijos</h3>
          </div>
          <div class="modern-card">
            <div class="feature-icon"><Landmark size={32} /></div>
            <h3>Bancos</h3>
          </div>
          <div class="modern-card">
            <div class="feature-icon"><ClipboardList size={32} /></div>
            <h3>RRHH / Planillas</h3>
          </div>
          <div class="modern-card">
            <div class="feature-icon"><Shield size={32} /></div>
            <h3>Seguridad</h3>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta">
      <div class="container">
        <div class="cta-card glassmorphism-card">
          <h2>¡Empieza a <span class="highlight">potencializar</span> tu empresa hoy!</h2>
          <p class="cta-desc">No lo pienses más y comienza a cambiar el futuro de tu negocio con la mejor solución del mercado.</p>
          <a href="https://wa.me/50494583355?text=Hola,%20me%20interesa%20obtener%20el%20ERP%20SICAD" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
            <MessageCircle size={24} />
            Contactar ahora
          </a>
        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>

<style>
  .sicad-page {
    padding-top: 64px;
    background: #f1f5f9;
  }

  /* Hero Section */
  .hero-section {
    padding: 2.5rem 0 5rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero-section .container {
    max-width: 1400px;
  }

  .hero-visual {
    margin-top: -3rem;
    position: relative;
    z-index: 10;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3rem;
  }

  @media (max-width: 991px) {
    .hero-section {
      padding: 3rem 0;
    }
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }
    .hero-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .hero-visual {
      order: -1;
      margin-top: 0;
    }
    .product-logo-container {
      justify-content: center !important;
    }
    .product-logo {
      margin: 0 auto !important;
    }
    h1, .hero-desc {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
    }
    .hero-actions {
      justify-content: center;
    }
  }

  .product-logo-container {
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
  }

  @media (min-width: 992px) {
    .product-logo-container {
      justify-content: flex-start;
    }
  }

  .product-logo {
    max-width: 240px;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  @media (min-width: 992px) {
    .product-logo {
      margin-left: 0;
      margin-right: auto;
    }
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 900;
    color: var(--text);
    margin-bottom: 2rem;
    line-height: 1.1;
    max-width: 800px;
    text-align: left;
  }

  .hero-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 2.5rem;
    text-align: left;
    max-width: 600px;
  }

  .hero-actions {
    display: flex;
    justify-content: flex-start;
  }

  .btn-primary-large {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--primary);
    color: white;
    padding: 1.25rem 2.5rem;
    border-radius: 4rem;
    font-weight: 800;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 20px rgba(0, 102, 204, 0.2);
  }

  .btn-primary-large:hover {
    background: var(--primary-dark);
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(0, 102, 204, 0.3);
  }

  .image-wrapper {
    position: relative;
    border-radius: 2.5rem;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.1);
    border: 8px solid white;
  }

  .main-hero-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease;
  }

  /* Benefits */
  .benefits-section {
    padding: 2rem 0 5rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 480px) {
    .benefits-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .benefit-card {
    background: white;
    padding: 2rem;
    border-radius: 1.5rem;
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: 0 10px 25px rgba(0,0,0,0.03);
    transition: transform 0.3s ease;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  @media (max-width: 480px) {
    .benefit-card {
      padding: 1.5rem;
    }
  }

  .benefit-card:hover { transform: translateY(-5px); }

  .icon-box {
    width: 60px;
    height: 60px;
    background: rgba(0, 102, 204, 0.05);
    color: var(--primary);
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
  }

  .benefit-card:hover .icon-box,
  .benefit-card:active .icon-box {
    background: var(--primary);
    color: white;
    transform: scale(1.1);
  }

  .benefit-card h3 { font-size: 1.2rem; margin-bottom: 0.5rem; font-weight: 800; }
  .benefit-card p { font-size: 1rem; color: var(--text-muted); line-height: 1.5; }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .badge {
    background: #e1effe;
    padding: 0.6rem 2.5rem;
    border-radius: 9999px;
    margin-bottom: 2rem;
    display: inline-block;
    border: 1px solid #bfdbfe;
    color: var(--primary);
    font-weight: 800;
  }

  .subtitle {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 800;
    color: var(--primary);
    font-size: 0.9rem;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: var(--text);
  }

  .highlight {
    color: var(--primary);
  }

  /* Desc Block */
  .desc-block-section {
    padding: 6rem 0;
    background: transparent;
  }

  .glass-desc-card {
    background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
    padding: 3rem 2rem;
    border-radius: 2rem;
    border: 1px solid rgba(0, 102, 204, 0.1);
    border-left: 6px solid var(--primary);
    box-shadow: 0 15px 40px rgba(0,0,0,0.06);
    text-align: left;
  }

  @media (max-width: 768px) {
    .glass-desc-card {
      padding: 2rem 1.5rem;
      text-align: center;
    }
    .desc-title {
      font-size: 1.75rem;
    }
  }

  .desc-title {
    font-size: 2.2rem;
    font-weight: 900;
    color: #111827;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .desc-content p { font-size: 1.15rem; color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.7; }
  .desc-content p:last-child { margin-bottom: 0; }
  .desc-content strong { color: var(--text); font-weight: 800; }

  /* Unique Features / Modules Grid */
  .features-section {
    padding: 6rem 0;
    background: transparent;
  }

  .features-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
  }

  .modern-card {
    flex: 0 0 calc(25% - 1.5rem);
    max-width: calc(25% - 1.5rem);
    padding: 2.5rem;
    border-radius: 2rem;
    background: #f8fafc;
    border: 1px solid rgba(0, 102, 204, 0.1);
    transition: all 0.3s ease;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .modern-card:hover {
    background: white;
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
  }

  @media (max-width: 991px) {
    .modern-card {
      flex: 0 0 calc(33.333% - 1.35rem);
      max-width: calc(33.333% - 1.35rem);
    }
  }

  @media (max-width: 768px) {
    .modern-card {
      flex: 0 0 calc(50% - 1rem);
      max-width: calc(50% - 1rem);
    }
  }

  @media (max-width: 480px) {
    .modern-card {
      flex: 0 0 100%;
      max-width: 100%;
    }
  }

  .feature-icon { 
    width: 60px;
    height: 60px;
    background: rgba(0, 102, 204, 0.05);
    color: var(--primary); 
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem; 
    transition: all 0.3s ease; 
  }

  .modern-card:hover .feature-icon,
  .modern-card:active .feature-icon {
    background: var(--primary);
    color: white;
    transform: scale(1.1);
  }

  /* Final CTA */
  .final-cta {
    padding: 2rem 2rem 8rem;
    background: transparent;
  }

  .glassmorphism-card {
    background: #ffffff;
    padding: 4rem 2rem;
    border-radius: 2.5rem;
    max-width: 800px;
    margin: 0 auto;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 102, 204, 0.1);
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }

  @media (max-width: 768px) {
    .glassmorphism-card {
      padding: 3rem 1.5rem;
      text-align: center;
      align-items: center;
    }
    .final-cta h2 {
      font-size: 2rem;
    }
  }
  .cta-desc { font-size: 1.2rem; margin: 0 0 2rem 0; color: var(--text-muted); max-width: 700px; }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: #25D366;
    color: white;
    padding: 1rem 2rem;
    border-radius: 3rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 20px rgba(37, 211, 102, 0.2);
    max-width: 100%;
  }

  @media (max-width: 480px) {
    .btn-whatsapp {
      padding: 1rem 1.5rem;
      width: 100%;
    }
  }

  .btn-whatsapp:hover {
    background: #128C7E;
    transform: translateY(-3px);
    box-shadow: 0 15px 30px rgba(37, 211, 102, 0.3);
  }

  @media (max-width: 991px) {
    .hero-grid { grid-template-columns: 1fr; text-align: center; gap: 4rem; }
    
    .hero-text {
      padding-top: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    
    .hero-visual {
      order: -1;
      margin-bottom: 3rem;
    }
    h1 { text-align: center; margin-left: auto; margin-right: auto; }
    .hero-desc { text-align: center; margin-left: auto; margin-right: auto; }
    .hero-actions { justify-content: center; }
    .glassmorphism-card { text-align: center; align-items: center; }
    .product-logo-container { justify-content: center; }
  }
</style>
