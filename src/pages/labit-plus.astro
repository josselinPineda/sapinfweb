<style>
  .labit-page {
    padding-top: 64px;
    background: #f1f5f9;
  }

  /* Hero Section */
  .hero-section {
    padding: 2.5rem 0 5rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero-section .container {
    max-width: 1400px;
  }

  .hero-visual {
    margin-top: -3rem;
    position: relative;
    z-index: 10;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3rem;
  }

  @media (max-width: 968px) {
    .hero-section { padding: 4rem 0; }
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }
    .hero-content {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .product-logo-container {
      justify-content: center !important;
    }
    .product-logo {
      margin: 0 auto !important;
    }
    h1, .hero-desc {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
    }
    .hero-actions {
      justify-content: center;
    }
    .hero-visual {
      margin-top: 0;
    }
  }

  .product-logo-container {
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
    width: 100%;
  }

  @media (min-width: 992px) {
    .product-logo-container {
      justify-content: flex-start;
    }
  }

  .product-logo {
    max-width: 240px;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  @media (min-width: 992px) {
    .product-logo {
      margin-left: 0;
      margin-right: auto;
    }
  }

  h1 {
    font-size: clamp(2.2rem, 4vw, 3rem);
    font-weight: 900;
    color: var(--text);
    margin-bottom: 2rem;
    line-height: 1.1;
    max-width: 800px;
    text-align: left;
  }

  .hero-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 2.5rem;
    text-align: left;
    max-width: 600px;
  }

  .hero-actions {
    display: flex;
    justify-content: flex-start;
  }

  .btn-primary-large {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--primary);
    color: white;
    padding: 1.25rem 2.5rem;
    border-radius: 4rem;
    font-weight: 800;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 20px rgba(0, 102, 204, 0.2);
  }

  .btn-primary-large:hover {
    background: var(--primary-dark);
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(0, 102, 204, 0.3);
  }

  .image-wrapper {
    position: relative;
    border-radius: 2.5rem;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.1);
    border: 8px solid white;
  }

  .main-hero-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease;
  }

  /* Benefits */
  .benefits-section {
    padding: 2rem 0 5rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .benefit-card {
    background: white;
    padding: 2rem;
    border-radius: 1.5rem;
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: 0 10px 25px rgba(0,0,0,0.03);
    transition: transform 0.3s ease;
  }

  .benefit-card:hover { transform: translateY(-5px); }

  .icon-box {
    width: 60px;
    height: 60px;
    background: rgba(0, 102, 204, 0.05);
    color: var(--primary);
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
  }

  .benefit-card:hover .icon-box,
  .benefit-card:active .icon-box {
    background: var(--primary);
    color: white;
    transform: scale(1.1);
  }

  .benefit-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .benefit-card p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.4; }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .badge {
    background: #e1effe;
    padding: 0.6rem 2.5rem;
    border-radius: 9999px;
    margin-bottom: 2rem;
    display: inline-block;
    border: 1px solid #bfdbfe;
    color: var(--primary);
    font-weight: 800;
  }

  .subtitle {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 800;
    color: var(--primary);
    font-size: 0.9rem;
  }

  h2 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 900;
    color: #111827;
    line-height: 1.1;
    margin-bottom: 2rem;
  }

  .highlight {
    color: var(--primary);
