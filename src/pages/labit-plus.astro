            </div>
            <a href="https://wa.me/50494583355?text=Hola,%20me%20interesa%20obtener%20el%20Plan%20Full%20de%20LABITPLUS" target="_blank" rel="noopener noreferrer" class="btn-primary-plan">
              Contáctanos
            </a>
          </div>
        </div>

        <!-- Comparison Table -->
        <div class="comparison-container">
           <div class="table-wrapper">
              <table class="comparison-table">
                 <thead>
                    <tr>
                       <th>Características</th>
                       <th>Básico</th>
                       <th>Intermedio</th>
