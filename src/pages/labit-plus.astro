---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { 
  Monitor, 
  Handshake, 
  Cloud, 
  Users, 
  CheckCircle2, 
  ShieldCheck, 
  ArrowRight,
  ClipboardList,
  Search,
  BarChart3,
  Calendar,
  Calculator,
  MessageCircle,
  Clock,
  Zap,
  Check
} from 'lucide-astro';

// Import assets
import labitLogo from '../assets/labitplus.png';
import labHero from '../assets/lab-fondo.jpg';
import mapaImage from '../assets/mapa-01.png';

const pageTitle = "LABITPLUS - Gestión de Laboratorios Clínicos";
---

<Layout title={pageTitle}>
  <Navbar />
  
  <main class="labit-page">
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container hero-grid">
        <div class="hero-content">
          <div class="badge">
            <span class="subtitle">Laboratorio de Análisis Clínicos</span>
          </div>
          <div class="product-logo-container">
            <img src={labitLogo.src} alt="LABITPLUS Logo" class="product-logo" />
          </div>
          <h1>¡Transforma tu laboratorio con&nbsp;<span style="color: var(--primary);">LABITPLUS!</span></h1>
          <p class="hero-desc">
            Software para la gestión de laboratorios de análisis clínicos desde el ingreso del paciente hasta la entrega de resultados. Mejora la eficiencia y precisión de tu laboratorio con tecnología de vanguardia.
          </p>
          <div class="hero-actions">
            <a href="https://wa.me/50494583355?text=Hola,%20me%20interesa%20obtener%20más%20información%20sobre%20LABITPLUS" target="_blank" rel="noopener noreferrer" class="btn-primary-large">
              <MessageCircle size={24} />
              Solicitar cotización
            </a>
          </div>
        </div>
        
        <div class="hero-visual">
          <div class="image-wrapper">
             <img src={labHero.src} alt="Labit Plus Dashboard" class="main-hero-image" />
          </div>
        </div>
      </div>
    </section>

    <!-- Key Benefits -->
    <section class="benefits-section">
      <div class="container">
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="icon-box"><Monitor size={28} /></div>
            <h3>Tecnología e innovación</h3>
            <p>A tu medida, adaptándose a las necesidades específicas de tu laboratorio.</p>
          </div>
          <div class="benefit-card">
            <div class="icon-box"><Zap size={28} /></div>
            <h3>Rapidez y confianza</h3>
            <p>Optimiza tiempos de entrega y garantiza resultados precisos.</p>
          </div>
          <div class="benefit-card">
            <div class="icon-box"><Cloud size={28} /></div>
            <h3>En línea</h3>
            <p>Acceso en todo momento desde cualquier lugar con conexión.</p>
          </div>
          <div class="benefit-card">
            <div class="icon-box"><Users size={28} /></div>
            <h3>Sin límites</h3>
            <p>Licencia para múltiples usuarios sin cargos adicionales por conexión.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Unique Features -->
    <section class="features-section">
      <div class="container">
        <div class="section-header text-center">
          <div class="badge">
            <span class="subtitle">Características</span>
          </div>
          <h2>Únicas y <span class="highlight">adaptadas</span> a su medida</h2>
        </div>

        <div class="features-grid">
          <div class="feature-card modern-card">
            <div class="feature-icon"><CheckCircle2 size={32} /></div>
            <h3>Eficacia</h3>
            <p>Le ayudamos a obtener el resultado deseado en cada proceso de análisis.</p>
          </div>
          <div class="feature-card modern-card">
            <div class="feature-icon"><Search size={32} /></div>
            <h3>Control</h3>
            <p>Le facilitamos la comprobación y trazabilidad de cada muestra clínica.</p>
          </div>
          <div class="feature-card modern-card">
            <div class="feature-icon"><BarChart3 size={32} /></div>
            <h3>Crecimiento</h3>
            <p>Nuestro software escala junto a su negocio, ayudándole a incrementar servicios.</p>
          </div>
          <div class="feature-card modern-card">
            <div class="feature-icon"><ShieldCheck size={32} /></div>
            <h3>Solidez</h3>
            <p>Garantiza una excelente fortaleza en sus procesos y seguridad de datos.</p>
          </div>
          <div class="feature-card modern-card">
            <div class="feature-icon"><ClipboardList size={32} /></div>
            <h3>Auditoría</h3>
            <p>Audite como todo un profesional con registros detallados de cada acción.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Description Block -->
    <section class="desc-block-section">
       <div class="container desc-grid">
          <div class="glass-desc-card">
             <div class="desc-content">
                <h3 class="desc-title">
                  Descubre la forma más <span class="highlight">sencilla</span> de optimizar tu laboratorio clínico.
                </h3>
                <p>LABITPLUS es una herramienta tecnológica que se utiliza para mejorar la eficiencia y precisión del proceso de análisis de muestras biológicas de su laboratorio clínico, con características principales como.</p>
                <p>Descubre cómo nuestro sistema revolucionará tus procesos, permitiendo a tus equipos maximizar la eficiencia y minimizar los costos. Con características de vanguardia y una interfaz intuitiva, nuestro sistema te brinda todas las herramientas necesarias para abordar tus necesidades más urgentes, sin requerir experiencia en programación y a un precio asequible.</p>
                <p><strong>Simplifica tus operaciones y potencia el potencial de tu laboratorio clínico con nosotros.</strong></p>
             </div>
          </div>
          <div class="video-container">
             <iframe src="https://www.youtube.com/embed/hPtrVqeNqz8" title="LABITPLUS Video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen class="promo-video"></iframe>
          </div>
       </div>
    </section>

    <!-- Plans Section -->
    <section id="planes" class="plans-section">
      <div class="container">
        <div class="section-header text-center">
          <div class="badge">
            <span class="subtitle">Suscripción</span>
          </div>
          <h2>Tenemos un <span class="highlight">plan perfecto</span> para ti</h2>
          <p class="section-desc">Selecciona la versión que mejor se adapte al volumen y necesidades de tu laboratorio.</p>
        </div>

        <div class="pricing-grid">
          <!-- Básico -->
          <div class="plan-card">
            <div class="plan-header">
              <h3>Básico</h3>
              <p>Ideal para iniciar</p>
            </div>
            <div class="plan-features">
              <ul class="feature-list">
                <li><Check size={18} class="check-icon" /> Administración y facturación</li>
                <li><Check size={18} class="check-icon" /> Control de pacientes y doctores</li>
                <li><Check size={18} class="check-icon" /> Generación de órdenes y boletas</li>
                <li><Check size={18} class="check-icon" /> Envío de resultados por WhatsApp</li>
                <li><Check size={18} class="check-icon" /> Seguridad y control de acceso</li>
              </ul>
            </div>
            <a href="https://wa.me/50494583355?text=Hola,%20me%20interesa%20obtener%20el%20Plan%20Básico%20de%20LABITPLUS" target="_blank" rel="noopener noreferrer" class="btn-primary-plan">
              Contáctanos
            </a>
          </div>

          <!-- Intermedio -->
          <div class="plan-card highlighted">
            <div class="plan-header">
              <div class="popular-badge">Recomendado</div>
              <h3>Intermedio</h3>
              <p>Solución integral</p>
            </div>
            <div class="plan-features">
              <ul class="feature-list">
                <li><Check size={18} class="check-icon" /> <strong>Todo lo del plan Básico</strong></li>
                <li><Check size={18} class="check-icon" /> Optimización de administración</li>
                <li><Check size={18} class="check-icon" /> Control profesional de pacientes</li>
                <li><Check size={18} class="check-icon" /> Resultados precisos y confiables</li>
              </ul>
            </div>
            <a href="https://wa.me/50494583355?text=Hola,%20me%20interesa%20obtener%20el%20Plan%20Intermedio%20de%20LABITPLUS" target="_blank" rel="noopener noreferrer" class="btn-primary-plan">
              Contáctanos
            </a>
          </div>

          <!-- Full -->
          <div class="plan-card">
            <div class="plan-header">
              <h3>Full</h3>
              <p>Máximo profesionalismo</p>
            </div>
            <div class="plan-features">
              <ul class="feature-list">
                <li><Check size={18} class="check-icon" /> <strong>Todo lo del plan Intermedio</strong></li>
                <li><Check size={18} class="check-icon" /> Facturación en múltiples monedas</li>
                <li><Check size={18} class="check-icon" /> Órdenes de trabajo masivas</li>
                <li><Check size={18} class="check-icon" /> Herramientas de alto nivel</li>
