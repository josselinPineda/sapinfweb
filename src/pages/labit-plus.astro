                    </tr>
                    <tr>
                       <td>Promociones en combo de exámenes.</td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                    </tr>
                    <tr>
                       <td>Configuración de CAI para la facturación.</td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                    </tr>
                    <tr>
                       <td>Control de pacientes/clientes.</td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                    </tr>
                    <tr>
                       <td>Control de Doctores.</td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                    </tr>
                    <tr>
                       <td>Ordenes/ Boletas de trabajo.</td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                    </tr>
                    <tr>
                       <td>Configuración de aliados o clínicas asociadas al laboratorio clínico.</td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                    </tr>
                    <tr>
                       <td>Parametrización de precios por asociado.</td>
                       <td><Check class="check" size={20} /></td>
