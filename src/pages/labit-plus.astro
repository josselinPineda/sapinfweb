                    </tr>
                    <tr>
                       <td>Cotizaciones (Aprobación, generación de boletas, facturación, envío por whatsapp/correo. Plan mensual).</td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                       <td><Check class="check" size={20} /></td>
                    </tr>
                    <tr>
                       <td>Envío de resultados por whatsapp/correo. Plan mensual.</td>
                       <td><Check class="check" size={20} /></td>
